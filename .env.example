# TechSpar launch configuration —— Only the "Boot Item" is placed here, not any API Key.
#
# LLM / Embedding / DashScope / Tavily / Alibaba Cloud OSS / All keys such as Tencent Cloud VPR,
# Each user must fill it out in "Settings" after logging in (there will be a two-step guide to guide you when logging in for the first time). LLM + Embedding).
# The same goes for the deployer: only the administrator account is configured here, and the model key is entered into the UI. They are not shared with each other, and each has its own account.

# NVIDIA API key (optional: if set, overrides other LLM providers and uses z-ai/glm-5.2 on integrate.api.nvidia.com)
# NVIDIA_API_KEY=nvapi-your-key-here

# High Security Mode (optional: if set to true, disables all optional external API integrations including Tavily, DashScope, Aliyun OSS, and Tencent VPR; and forces embedding to be local-only)
HIGH_SECURITY_MODE=false

# Auth
JWT_SECRET=change-me-in-production
DEFAULT_EMAIL=admin@techspar.local
DEFAULT_PASSWORD=admin123
DEFAULT_NAME=admin
# Whether to allow new users to register on the login page. When false, only the above DEFAULT_EMAIL/PASSWORD can log in.
# You can also use the settings page“Account”Switching in the label will take effect immediately when running (this file is only used as the initial value for the first startup).
ALLOW_REGISTRATION=false

# Interview tuning (optional)
MAX_QUESTIONS_PER_PHASE=5
MAX_DRILL_QUESTIONS=15
